{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "OLT Targets Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "count(gpon_up == 1)",
          "legendFormat": "Up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Total Active ONUs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(gpon_olt_active_onus)",
          "legendFormat": "ONUs"
        }
      ]
    },
    {
      "title": "ONUs Out of Spec",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "count(gpon_onu_signal_within_spec == 0) or vector(0)",
          "legendFormat": "Out of Spec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Active Alarms",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(gpon_olt_active_alarms)",
          "legendFormat": "Alarms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "OLT CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "gpon_olt_cpu_percent",
          "legendFormat": "{{target}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "OLT Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "gpon_olt_memory_percent",
          "legendFormat": "{{target}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100
        }
      }
    },
    {
      "title": "ONU Rx Power Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "gpon_onu_rx_power_dbm",
          "legendFormat": "{{target}} / {{serial}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": -28 },
              { "color": "green", "value": -25 },
              { "color": "orange", "value": -10 },
              { "color": "red", "value": -8 }
            ]
          }
        }
      }
    },
    {
      "title": "ONU Tx Power Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "gpon_onu_tx_power_dbm",
          "legendFormat": "{{target}} / {{serial}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dBm"
        }
      }
    },
    {
      "title": "ONUs per PON Port",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "gpon_pon_port_onu_count",
          "legendFormat": "{{target}} / {{pon_port}}"
        }
      ]
    },
    {
      "title": "ONU Distance (meters)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "gpon_onu_distance_meters",
          "legendFormat": "{{target}} / {{serial}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "lengthm"
        }
      }
    },
    {
      "title": "OLT Temperature",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "gpon_olt_temperature_celsius",
          "legendFormat": "{{target}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius"
        }
      }
    },
    {
      "title": "Scrape Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "gpon_scrape_duration_seconds",
          "legendFormat": "{{target}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["gpon", "pon-exporter", "fiber"],
  "templating": {
    "list": [
      {
        "name": "target",
        "type": "query",
        "query": "label_values(gpon_up, target)",
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "GPON Overview",
  "uid": "gpon-overview"
}
